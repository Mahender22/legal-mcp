# LegalMCP Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# ─── CourtListener (FREE) ──────────────────────────────────────
# Get a free API token at https://www.courtlistener.com/sign-in/
# Optional: works without token but with lower rate limits
COURTLISTENER_TOKEN=

# ─── Clio Practice Management (Pro plan) ───────────────────────
# Get OAuth token at https://developer.clio.com
CLIO_TOKEN=

# ─── PACER Federal Court Filings (Pro plan) ────────────────────
# Register at https://pacer.uscourts.gov
# Note: PACER charges $0.10/page for document access
PACER_USERNAME=
PACER_PASSWORD=

# ─── Demo Mode ─────────────────────────────────────────────────
# Set to "true" to use pre-cached sample data (no API keys needed)
LEGAL_MCP_DEMO=false
